class HoudiniApexScene "HoudiniApexScene" (
    doc = """Houdini primitive schema representing an APEX animation scene.

        Characters can be bound to the scene via the
        HoudiniApexCharacterBindingAPI multiple-apply API schema.
        """
)
{
    uniform bool[] inheritAnimationLayers = [] (
        doc = """For each entry in sceneFiles, indicates whether existing
            animation layers are inherited from the input scene when applying
            the scene delta.
            """
    )
    uniform asset[] sceneFiles = [] (
        doc = """List of geometry files to merge into the APEX scene. These are
            loaded after the characters' geometry files (from
            HoudiniApexCharacterAPI) and typically contain animation and
            constraints.
            """
    )
}

class "HoudiniApexCharacterBindingAPI" (
    doc = """Houdini API schema for adding a character to an APEX animation
        scene. This is intended for use with HoudiniApexScene prims.

        The schema's instance name (e.g. 'electra') is used as the character's
        name in the APEX scene (e.g. '/electra.char')
        """
)
{
    rel character:__INSTANCE_NAME__:binding (
        doc = """Relationship specifying the character to bind to the scene (a
            primitive with the HoudiniApexCharacterAPI schema).
            """
    )
    uniform string character:__INSTANCE_NAME__:rig = "" (
        doc = """Specifies which rig to use for the character (for example,
            \"Base.rig\"). If authored, this value takes precedence over the
            'houdini:apex:character:rig' attribute from HoudiniApexCharacterAPI.
            """
    )
}

class "HoudiniApexCharacterAPI" (
    doc = """Houdini API schema for a character that can be bound to an APEX
        animation scene.

        USD primitives can be bound to the rig's geometry inputs and outputs via
        the HoudiniApexShapeBindingAPI multiple-apply API schema. 
        """
)
{
    uniform asset[] houdini:apex:character:files = [] (
        doc = """List of geometry files to merge into the APEX scene under the
            character's path. These typically contain the rig, skeleton,
            controls, etc for the character."""
    )
    uniform string houdini:apex:character:rig = "" (
        doc = """Specifies which rig to use for the character (for example,
            \"Base.rig\"). If not specified, the first character element matching
            '*.rig' is used.
            """
    )
}

class "HoudiniApexShapeBindingAPI" (
    doc = """Houdini API schema for binding a USD primitive to a geometry input
        and/or output of an APEX character's rig. This is intended for use with
        the HoudiniApexCharacterAPI schema.
        """
)
{
    rel houdini:apex:shape:__INSTANCE_NAME__:binding (
        doc = """Relationship to a primitive that will be bound to an input or
            output of the character's rig. 
            """
    )
    uniform string houdini:apex:shape:__INSTANCE_NAME__:input = "" (
        doc = "Optional name of a rig input to bind the primitive to."
    )
    uniform string houdini:apex:shape:__INSTANCE_NAME__:output = "" (
        doc = "Optional name of a rig output which deforms the primitive."
    )
}

class "HoudiniApexShapeDeformAPI" (
    doc = """Houdini API schema for describing input data for deformers
        (e.g. capture weights) on a point-based prim.
        """
)
{
    uniform token[] houdini:apex:deform:joints (
        doc = """An array of tokens defining the list of joints to which
        jointIndices apply. This attribute is required if jointIndices is
        defined."""
    )
    int[] primvars:houdini:apex:deform:jointIndices (
        doc = """Indices into the *joints* attribute that affect each point of
        a PointBased gprim. The primvar can have either *constant* or *vertex*
        interpolation. This primvar's *elementSize* will determine how many
        joint influences apply to each point. Indices must point be valid. Null
        influences should be defined by setting values in jointWeights to zero.
        See UsdGeomPrimvar for more information on interpolation and
        elementSize."""
    )
    float[] primvars:houdini:apex:deform:jointWeights (
        doc = """Weights for the joints that affect each point of a PointBased
        gprim. The primvar can have either *constant* or *vertex* interpolation.
        This primvar's *elementSize* will determine how many joints influences
        apply to each point. The length, interpolation, and elementSize of
        *jointWeights* must match that of *jointIndices*. See UsdGeomPrimvar
        for more information on interpolation and elementSize."""
    )
}

